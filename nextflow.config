nextflow.enable.dsl=2

manifest {
    name = 'ChIPalign_NF'
    description = 'An end-to-end ChIP-seq pipeline for alignment, peak calling, and motif analysis'
    mainScript = 'chipseq_merged.nf'
}

params {
    input = "$projectDir/assets/samplesheet.chipseq.csv"
    input_mode = 'fastq'
    outdir = 'results'
    project = 'ChIPalign_NF'

    ref = '/lustre/home/acct-medkkw/medlyb/database/annotation/gatk_ann/hg38/bowtie2index2/Homo_sapiens_assembly38.fasta'
    genome = 'hg38'
    effective_genome_size = 2913022398

    balance_bam = false
    balance_pairs = 10000000
    run_motif = false

    macs2_tf_qvalue = 0.01
    macs2_histone_pvalue = '1e-9'
    macs2_noctrl_qvalue = 0.01
    macs2_noctrl_keep_dup = 1
    macs2_noctrl_extsize = 250

    motif_size = 200
    motif_len = '6,8,12,16,20'
    motif_mknown = '/lustre/home/acct-medkkw/medlyb/wl_proj/WL234_Lib/database/JASPAR/JASPAR2020_CORE_vertebrates_non-redundant_pfms_homer.txt'
}

process {
	cpus = 4
	memory = { 4.GB * task.cpus }
}
